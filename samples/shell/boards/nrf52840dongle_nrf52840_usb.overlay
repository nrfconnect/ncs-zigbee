#include "nrf52840dongle_nrf52840.overlay"
 
/*
 * For nrf52840dongle the board already includes cdc_acm_serial.dtsi which
 * defines board_cdc_acm_uart and sets zephyr,shell-uart. Do not include
 * app_usb.overlay here or it would add a duplicate cdc_acm_uart node and
 * override shell-uart to it.
 */
